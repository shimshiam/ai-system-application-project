flowchart LR
    subgraph IN["Inputs"]
        A1[songs.csv]
        A2[study_rules.csv]
        A3[Spotify API]
    end

    subgraph INGEST["Spotify Client"]
        B1[Fetch Genres] --> B2[Normalize] --> B3{Classify}
        B3 -->|LLM| B4[OpenAI]
        B3 -->|No key| B5[Heuristic]
    end

    subgraph DASH["Streamlit UI"]
        C1[Source] --- C2[Context]
        C3[Synthesis] --- C4[Filters]
    end

    subgraph RETRIEVE["RAG Retriever"]
        D1[Match Rules] --> D3[Build Context]
        D2[Score + Rank Songs] --> D3
    end

    subgraph SCORE["Scorer Engine"]
        E1[Balanced]
        E2[Genre-First]
        E3[Mood-First]
        E4[Energy]
        E5[Resonance]
    end

    subgraph GEN["Generator"]
        F1{Plan} -->|LLM| F2[OpenAI JSON]
        F1 -->|Fallback| F3[Deterministic]
        F2 --> F4[Grounding Guard]
    end

    subgraph OUT["Output"]
        G1[Playlist + Reasons]
        G2[Study Strategy]
        G3[Retrieval Context]
    end

    subgraph TEST["Testing + Human Review"]
        H1[test_recommender.py]
        H2[test_spotify_client.py]
        H3[test_study_dj.py]
        H4[Human reviews output in UI]
    end

    A1 & A3 --> INGEST --> DASH
    A2 --> RETRIEVE
    DASH -->|Request + Songs| RETRIEVE
    RETRIEVE -->|Prefs| SCORE
    SCORE -->|Ranked| RETRIEVE
    D3 -->|Context| GEN
    F4 & F3 --> OUT --> DASH

    H1 -.-> SCORE
    H2 -.-> INGEST
    H3 -.-> RETRIEVE
    H3 -.-> GEN
    H4 -.-> OUT
